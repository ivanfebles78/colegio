# ----------------------------------------------------------------------------
# Base de datos PostgreSQL
# ----------------------------------------------------------------------------
DATABASE_URL="postgresql://shop:shop@localhost:5432/britanico_shop?schema=public"

# ----------------------------------------------------------------------------
# Stripe (modo TEST)
#   Crea cuenta en https://dashboard.stripe.com y usa las claves de TEST.
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ----------------------------------------------------------------------------
# Email (Resend) — necesario para notificaciones reales
#   https://resend.com → API Keys
# ----------------------------------------------------------------------------
RESEND_API_KEY=""
NOTIFICATION_FROM_EMAIL="reservas@britanicos21.es"
NOTIFICATION_REPLY_TO=""

# ----------------------------------------------------------------------------
# SMS / WhatsApp (Twilio) — preparado pero DESACTIVADO por defecto.
#   Cambia NOTIFICATIONS_SMS_ENABLED=true cuando se contrate.
# ----------------------------------------------------------------------------
NOTIFICATIONS_SMS_ENABLED="false"
NOTIFICATIONS_WHATSAPP_ENABLED="false"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# ----------------------------------------------------------------------------
# Panel de administración
#   ADMIN_PASSWORD_HASH se genera con bcrypt (10 rounds).
#   Para crear uno nuevo en local:
#     node -e "console.log(require('bcryptjs').hashSync('TU_PASSWORD', 10))"
#   Genera UN HASH NUEVO con: npm run admin:hash -- TuContraseña
#   NO COPIES los valores de este archivo: son rellenos. Si los usas tal cual,
#   no podrás loguearte (el hash no corresponde a ninguna contraseña real) y
#   el SESSION_SECRET es público en GitHub.
# ----------------------------------------------------------------------------
ADMIN_USERNAME="admin"
ADMIN_PASSWORD_HASH="<<GENERAR_CON_npm_run_admin:hash>>"
ADMIN_SESSION_SECRET="<<GENERAR_CON_npm_run_admin:hash>>"

# ----------------------------------------------------------------------------
# Branding del colegio (sobrescribe valores por defecto de school-config.ts)
#   Cambia estos valores para hacer demo a otro colegio sin tocar código.
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SCHOOL_NAME="Centro Educativo Británico S21"
NEXT_PUBLIC_SCHOOL_SHORT_NAME="Británico S21"
NEXT_PUBLIC_SCHOOL_LOCATION="La Laguna, Tenerife"
NEXT_PUBLIC_SCHOOL_DOMAIN="britanicos21.es"
NEXT_PUBLIC_SCHOOL_PRIMARY_HSL="158 36% 16%"
NEXT_PUBLIC_SCHOOL_ACCENT_HSL="39 42% 60%"
NEXT_PUBLIC_SCHOOL_PHONE="922 25 80 19"
NEXT_PUBLIC_SCHOOL_EMAIL="info@britanicos21.es"
